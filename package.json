{
    "name": "nullspace",
    "version": "1.1.1",
    "description": "ssrf prevention library for node.js",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles",
